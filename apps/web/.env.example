# ============================================
# Convex
# ============================================

# Required — Convex deployment URL
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Optional — Convex site URL for auth configuration
# CONVEX_SITE_URL=https://your-site.convex.site

# ============================================
# Authentication (JWT)
# ============================================

# Required — JWK key pair for signing/verifying grant tokens
# Generate with: bun run scripts/generate_keys.ts
PRIVATE_KEY_JWK={"kty":"EC","crv":"P-256","x":"...","y":"...","d":"..."}
PUBLIC_KEY_JWK={"kty":"EC","crv":"P-256","x":"...","y":"..."}

# ============================================
# Webhooks
# ============================================

# Required — Secret for validating webhook HMAC signatures
WEBHOOK_SECRET=your-webhook-secret-here

# Required — Secret for validating internal action calls
ACTION_SECRET=your-action-secret-here

# ============================================
# Polar (Payments)
# ============================================

# Required — Polar API organization token
POLAR_ORGANIZATION_TOKEN=your-polar-org-token

# Required — Polar environment: "sandbox" or "production"
POLAR_SERVER=sandbox

# Required — Polar product IDs
NEXT_PUBLIC_POLAR_PRODUCT_FREEMIUM=your-freemium-product-id
NEXT_PUBLIC_POLAR_PRODUCT_STANDARD=your-standard-product-id

# ============================================
# Analytics
# ============================================

# Required — PostHog project API key
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key

# ============================================
# App Configuration
# ============================================

# Optional — Documentation site URL (defaults to docs site)
# NEXT_PUBLIC_DOCS_URL=https://docs.erebus.sh

# Optional — Set to "true" to disable project creation in the UI
# NEXT_PUBLIC_EREBUS_ON_HOLD=false
