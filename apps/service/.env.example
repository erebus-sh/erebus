# ============================================
# Authentication
# ============================================

# Required — JWK public key for verifying grant JWTs (must match apps/web PRIVATE_KEY_JWK pair)
PUBLIC_KEY_JWK={"kty":"EC","crv":"P-256","x":"...","y":"..."}

# Required — Root API key for admin operations
ROOT_API_KEY=your-root-api-key-here

# ============================================
# Upstash Redis
# ============================================

# Required — Upstash Redis REST API endpoint
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io

# Required — Upstash Redis REST API token
UPSTASH_REDIS_REST_TOKEN=your-upstash-token-here

# ============================================
# Webhooks
# ============================================

# Required — Base URL for webhook delivery
WEBHOOK_BASE_URL=https://your-app.convex.site

# Required — Secret for webhook HMAC signatures
WEBHOOK_SECRET=your-webhook-secret-here

# ============================================
# Debug
# ============================================

# Optional — Enable debug mode (set in wrangler.jsonc vars)
# DEBUG=true

# Optional — Enable verbose debug logging in hot paths
# EREBUS_DEBUG_VERBOSE=true
